{
  "name": "@panopticon/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "bun test",
    "clean": "rm -rf dist",
    "db:migrate": "bun run src/db/migrate.ts"
  },
  "dependencies": {
    "@panopticon/shared": "workspace:*",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.1",
    "@clickhouse/client": "^1.8.0",
    "postgres": "^3.4.4",
    "ioredis": "^5.4.1",
    "bullmq": "^5.25.0",
    "nanoid": "^5.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.3"
  }
}
