# =============================================================================
# Panopticon — Environment configuration
# Copy to .env and customize as needed
# =============================================================================

# Ports (change if conflicts with other services)
API_PORT=4400
DASHBOARD_PORT=3000

# PostgreSQL
POSTGRES_USER=panopticon
POSTGRES_PASSWORD=panopticon
POSTGRES_DB=panopticon
POSTGRES_PORT=5432

# ClickHouse
CLICKHOUSE_DB=panopticon
CLICKHOUSE_USER=default
CLICKHOUSE_PORT=8123

# Redis
REDIS_PORT=6379

# LLM Integration (optional — enables semantic security, trace analysis, NL query)
# Uncomment ONE provider block below. Leave all commented out to disable LLM features.
# When disabled, security classification falls back to regex (still works, just less accurate).

# ── OpenAI ──
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Anthropic ──
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# ── Ollama (local, no API key needed) ──
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# LLM_BASE_URL=http://host.docker.internal:11434/v1
