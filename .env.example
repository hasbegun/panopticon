# =============================================================================
# Panopticon — Environment configuration
# Copy to .env and customize as needed
# =============================================================================

# Ports (change if conflicts with other services)
API_PORT=4400
DASHBOARD_PORT=3000

# PostgreSQL
POSTGRES_USER=panopticon
POSTGRES_PASSWORD=panopticon
POSTGRES_DB=panopticon
POSTGRES_PORT=5432

# ClickHouse
CLICKHOUSE_DB=panopticon
CLICKHOUSE_USER=default
CLICKHOUSE_PORT=8123

# Redis
REDIS_PORT=6379

# LLM Integration (optional — enables semantic security, trace analysis, NL query)
# LLM_PROVIDER=openai          # openai | anthropic | ollama
# LLM_API_KEY=sk-...           # API key (not needed for Ollama)
# LLM_MODEL=gpt-4o-mini        # Model name (auto-selected if unset)
# LLM_BASE_URL=                 # Custom base URL (e.g. http://ollama:11434/v1 for Ollama)
